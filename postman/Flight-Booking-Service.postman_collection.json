{
  "info": {
    "name": "Flight Booking Service",
    "description": "POST /api/v1/bookings — run app on http://localhost:8080 (default).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking — success (AA101)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightNumber\": \"AA101\",\n  \"passengerName\": \"Jane Doe\",\n  \"seatsRequested\": 2\n}"
            },
            "url": "{{baseUrl}}/api/v1/bookings"
          }
        },
